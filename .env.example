# Connection string do PostgreSQL (deve apontar para o banco do docker-compose)
DATABASE_URL=postgresql+asyncpg://aiops:aiops123@localhost:5432/aiops_k8s

# Chave de API da Anthropic (obrigatorio quando usar agentes)
